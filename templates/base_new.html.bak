<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Amaren - Sistema de Gestão de Produção">
    <meta name="theme-color" content="#4f46e5">
    
    <title>{% block title %}Amaren - Gestão Farmacêutica{% endblock %}</title>
    
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    
    <!-- Google Fonts - Inter (Modern & Clean) -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Main CSS - Design System -->
    <link rel="stylesheet" href="{% static 'css/main.css' %}">
    
    <!-- Extra CSS Block for página-specific styles -->
    {% block extra_css %}{% endblock %}
    
    <style>
        /* Compatibilidade Bootstrap (se necessário) */
        .container-fluid {
            padding-left: 0;
            padding-right: 0;
        }
        
        /* Override Bootstrap alerts para seguir design system */
        .alert {
            border: none;
            border-left: 4px solid;
            padding: 1rem;
            border-radius: 0.75rem;
        }
        
        .alert-primary {
            background-color: var(--color-primary-50);
            color: var(--color-primary-700);
            border-left-color: var(--color-primary-600);
        }
        
        .alert-success {
            background-color: var(--color-success-50);
            color: var(--color-success-700);
            border-left-color: var(--color-success-600);
        }
        
        .alert-warning {
            background-color: var(--color-warning-50);
            color: var(--color-warning-700);
            border-left-color: var(--color-warning-600);
        }
        
        .alert-danger {
            background-color: var(--color-danger-50);
            color: var(--color-danger-700);
            border-left-color: var(--color-danger-600);
        }
    </style>
    
    {% load static %}
</head>
<body>
    {% if user.is_authenticated %}
        <!-- NAVBAR -->
        <header class="navbar">
            <div class="navbar-brand">
                <i class="bi bi-trophy-fill"></i>
                <span>Amaren</span>
            </div>
            
            <div class="navbar-content">
                <div class="navbar-user">
                    <div class="navbar-user-avatar">
                        {{ user.first_name|first|upper }}
                    </div>
                    <div class="navbar-user-info">
                        <div class="navbar-user-info-name">{{ user.get_full_name|default:user.username }}</div>
                        <div class="navbar-user-info-role">
                            {% if user.is_superuser %}
                                Administrador
                            {% elif user.groups.all %}
                                {{ user.groups.all|first }}
                            {% else %}
                                Funcionário
                            {% endif %}
                        </div>
                    </div>
                    
                    <!-- Menu Dropdown -->
                    <div style="position: relative;">
                        <button class="btn-icon" id="userMenuToggle" style="background: rgba(255,255,255,0.2); color: white; border: none;">
                            <i class="bi bi-chevron-down"></i>
                        </button>
                        <div id="userMenu" style="display: none; position: absolute; top: 100%; right: 0; background: white; border-radius: 0.75rem; box-shadow: 0 10px 25px rgba(0,0,0,0.1); min-width: 200px; z-index: var(--z-dropdown);">
                            <a href="{% url 'core:meu_perfil' %}" class="d-flex align-items-center" style="padding: 0.75rem 1rem; text-decoration: none; color: var(--text-primary); border-bottom: 1px solid var(--border-color-light);">
                                <i class="bi bi-person" style="margin-right: 0.5rem;"></i> Meu Perfil
                            </a>
                            <form method="post" action="{% url 'logout' %}" style="margin: 0;">
                                {% csrf_token %}
                                <button type="submit" style="padding: 0.75rem 1rem; width: 100%; text-align: left; border: none; background: none; cursor: pointer; color: var(--text-primary); display: flex; align-items: center; gap: 0.5rem;">
                                    <i class="bi bi-box-arrow-right"></i> Sair
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </header>
        
        <div class="layout">
            <!-- SIDEBAR -->
            <aside class="layout-sidebar">
                <nav class="sidebar">
                    {% block sidebar %}
                        {% if 'Gerente' in user.groups.all|dictsort:"name"|join:"," or user.is_superuser %}
                            {% include "includes/sidebar_gerente_admin.html" %}
                        {% else %}
                            <!-- Sidebar Funcionário -->
                            <div class="sidebar-title">Produção</div>
                            <ul style="list-style: none; padding: 0; margin: 0;">
                                <li class="nav-item">
                                    <a class="nav-link {% if request.resolver_match.url_name == 'formulas_disponiveis' %}active{% endif %}" href="{% url 'dashboard:formulas_disponiveis' %}">
                                        <i class="bi bi-list-task"></i>
                                        <span>Fórmulas Disponíveis</span>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link {% if request.resolver_match.url_name == 'minhas_formulas' %}active{% endif %}" href="{% url 'dashboard:minhas_formulas' %}">
                                        <i class="bi bi-bookmark-fill"></i>
                                        <span>Minhas Fórmulas</span>
                                    </a>
                                </li>
                            </ul>
                            
                            <div class="sidebar-title">Logística</div>
                            <ul style="list-style: none; padding: 0; margin: 0;">
                                <li class="nav-item">
                                    <a class="nav-link {% if request.resolver_match.url_name == 'rotas_unificada' %}active{% endif %}" href="{% url 'dashboard:rotas_unificada' %}">
                                        <i class="bi bi-truck"></i>
                                        <span>Gerenciar Rotas</span>
                                    </a>
                                </li>
                            </ul>
                            
                            <div class="sidebar-title">Qualidade</div>
                            <ul style="list-style: none; padding: 0; margin: 0;">
                                <li class="nav-item">
                                    <a class="nav-link {% if request.resolver_match.url_name == 'controle_qualidade' %}active{% endif %}" href="{% url 'dashboard:controle_qualidade' %}">
                                        <i class="bi bi-clipboard-check"></i>
                                        <span>Controle de Qualidade</span>
                                    </a>
                                </li>
                            </ul>
                            
                            <div class="sidebar-title">Minha Conta</div>
                            <ul style="list-style: none; padding: 0; margin: 0;">
                                <li class="nav-item">
                                    <a class="nav-link {% if request.resolver_match.url_name == 'perfil_funcionario' %}active{% endif %}" href="{% url 'dashboard:perfil_funcionario' %}">
                                        <i class="bi bi-person-badge"></i>
                                        <span>Meu Perfil</span>
                                    </a>
                                </li>
                            </ul>
                        {% endif %}
                    {% endblock %}
                </nav>
            </aside>
            
            <!-- MAIN CONTENT -->
            <main class="layout-content">
                <!-- Alertas e Mensagens -->
                {% if messages %}
                    <div style="margin-bottom: var(--space-lg);">
                        {% for message in messages %}
                            <div class="alert alert-{{ message.tags }} d-flex align-items-center" role="alert">
                                <i class="bi bi-exclamation-circle" style="margin-right: var(--space-md);"></i>
                                <div>{{ message }}</div>
                                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close" style="margin: 0;"></button>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
                
                <!-- Conteúdo da Página -->
                {% block content %}{% endblock %}
            </main>
        </div>
        
        <!-- Mobile Menu Toggle -->
        <button id="mobileMenuToggle" class="btn btn-primary" style="position: fixed; bottom: 2rem; right: 2rem; width: 60px; height: 60px; border-radius: 50%; display: none; z-index: 999; padding: 0; display: flex !important; align-items: center; justify-content: center;">
            <i class="bi bi-list" style="font-size: 1.5rem;"></i>
        </button>
    {% else %}
        <!-- Login Layout -->
        {% block login_content %}{% endblock %}
    {% endif %}
    
    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    
    <script>
        // User Menu Toggle
        document.getElementById('userMenuToggle').addEventListener('click', function() {
            const menu = document.getElementById('userMenu');
            menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
        });
        
        // Fechar menu ao clicar fora
        document.addEventListener('click', function(event) {
            const userMenu = document.getElementById('userMenu');
            const userMenuToggle = document.getElementById('userMenuToggle');
            if (!event.target.closest('#userMenuToggle') && !event.target.closest('#userMenu')) {
                userMenu.style.display = 'none';
            }
        });
        
        // Mobile Menu Toggle
        const mobileMenuToggle = document.getElementById('mobileMenuToggle');
        const layoutSidebar = document.querySelector('.layout-sidebar');
        
        function updateMobileMenuVisibility() {
            if (window.innerWidth <= 768) {
                mobileMenuToggle.style.display = 'flex';
            } else {
                mobileMenuToggle.style.display = 'none';
                if (layoutSidebar) {
                    layoutSidebar.classList.remove('active');
                }
            }
        }
        
        if (mobileMenuToggle) {
            mobileMenuToggle.addEventListener('click', function() {
                layoutSidebar?.classList.toggle('active');
            });
        }
        
        window.addEventListener('resize', updateMobileMenuVisibility);
        updateMobileMenuVisibility();
        
        // Alert auto-close
        const alerts = document.querySelectorAll('.alert');
        alerts.forEach(alert => {
            setTimeout(() => {
                const bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            }, 5000);
        });
    </script>
    
    {% block extra_js %}{% endblock %}
</body>
</html>
